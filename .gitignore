*.lcov
.nyc_output

# ---------- next.js ----------
/.next/
/out/
.next
next-env.d.ts

# ---------- production / build ----------
/build
/dist

# ---------- env files ----------
.env
.env.*
!.env.example

# ---------- logs ----------
